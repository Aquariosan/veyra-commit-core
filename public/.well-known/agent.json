{
  "schema_version": "1.0",
  "name": "Veyra",
  "description": "Commit mode for production AI agent writes. 48 MCP tools in one endpoint. Free discovery, free verification, settlement-based pricing.",
  "url": "https://veyra.to",
  "type": "infrastructure",
  "capabilities": ["trust_discovery", "action_authorization", "token_verification", "settlement", "mcp_tools"],
  "mcp": {
    "sse_endpoint": "https://mcp.veyra.to/sse",
    "tools": 48,
    "free_reads": 24,
    "protected_writes": 24,
    "manifest": "https://mcp.veyra.to/.well-known/veyra-pack.json"
  },
  "api": {
    "base_url": "https://api.veyra.to/v1",
    "openapi": "https://veyra.to/openapi.json"
  },
  "sdk": {
    "install": "npm install @veyrahq/sdk-node",
    "npm": "https://www.npmjs.com/package/@veyrahq/sdk-node"
  },
  "documentation": {
    "llms_txt": "https://veyra.to/llms.txt",
    "llms_full_txt": "https://veyra.to/llms-full.txt",
    "docs": "https://veyra.to/docs"
  },
  "discovery": [
    "https://veyra.to/.well-known/ai-manifest.json",
    "https://veyra.to/.well-known/ai-plugin.json",
    "https://veyra.to/.well-known/mcp.json",
    "https://veyra.to/.well-known/veyra.json",
    "https://veyra.to/.well-known/openai-configuration.json"
  ]
}
